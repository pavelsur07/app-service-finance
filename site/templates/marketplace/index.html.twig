{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'marketplace' %}

{% block tab_content %}
    <div class="p-3">

        {# Подключения #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">Активные подключения</h3>
                <div class="card-actions">
                    <a href="#" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add-connection">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Добавить подключение
                    </a>
                </div>
            </div>
            <div class="card-body">
                {% if connections is empty %}
                    <div class="empty">
                        <div class="empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="7" cy="18" r="2" /><circle cx="7" cy="6" r="2" /><circle cx="17" cy="12" r="2" /><line x1="7" y1="8" x2="7" y2="16" /><path d="M7 8a4 4 0 0 0 4 4h4" /></svg>
                        </div>
                        <p class="empty-title">Нет активных подключений</p>
                        <p class="empty-subtitle text-muted">Добавьте подключение к маркетплейсу для начала работы</p>
                    </div>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for connection in connections %}
                            <div class="list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <span class="avatar">{{ connection.marketplace.value|slice(0,2)|upper }}</span>
                                    </div>
                                    <div class="col text-truncate">
                                        <div class="text-reset d-block">{{ connection.marketplace.displayName }}</div>
                                        <div class="d-block text-muted text-truncate mt-n1">
                                            {% if connection.clientId %}
                                                Client-Id: {{ connection.clientId }} &middot;
                                            {% endif %}
                                            API Key: {{ connection.apiKey|slice(0, 20) }}***
                                        </div>
                                        <div class="d-block text-muted mt-1"
                                             data-connection-id="{{ connection.id }}"
                                             data-status-url="{{ path('marketplace_connection_status', {id: connection.id}) }}"
                                             data-synced="{{ connection.lastSyncAt ? '1' : '0' }}"
                                             id="connection-status-{{ connection.id }}">
                                            {% if connection.lastSyncAt %}
                                                <small>Последняя синхронизация: {{ connection.lastSyncAt|date('d.m.Y H:i') }}</small>
                                            {% else %}
                                                <small class="text-warning">
                                                    <span class="spinner-border spinner-border-sm me-1" style="width:.7rem;height:.7rem"></span>
                                                    Первичная загрузка данных...
                                                </small>
                                            {% endif %}
                                        </div>
                                        {% if connection.lastSyncError %}
                                            <div class="text-danger mt-1">
                                                <small>Ошибка: {{ connection.lastSyncError|slice(0, 100) }}</small>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-auto">
                                    <span class="badge bg-{{ connection.isActive ? 'success' : 'secondary' }}">
                                        {{ connection.isActive ? 'Активно' : 'Неактивно' }}
                                    </span>
                                    </div>
                                    <div class="col-auto">
                                        <div class="btn-list">
                                            <a href="{{ path('marketplace_connection_test', {id: connection.id}) }}" class="btn btn-sm btn-outline-info">Проверить</a>
                                            <a href="{{ path('marketplace_connection_sync', {id: connection.id}) }}" class="btn btn-sm btn-primary">Синхронизировать</a>
                                            <a href="#" class="btn btn-sm btn-outline-primary"
                                               data-bs-toggle="modal"
                                               data-bs-target="#modal-sync-period"
                                               data-connection-id="{{ connection.id }}">За период</a>
                                            <a href="{{ path('marketplace_connection_toggle', {id: connection.id}) }}" class="btn btn-sm btn-outline-secondary">
                                                {{ connection.isActive ? 'Деактивировать' : 'Активировать' }}
                                            </a>
                                            <form method="post" action="{{ path('marketplace_connection_delete', {id: connection.id}) }}" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Удалить подключение?')">Удалить</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# ============================================================= #}
        {# Генерация ОПиУ — НОВАЯ КАРТОЧКА                               #}
        {# ============================================================= #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-report-analytics me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2" /><rect x="9" y="3" width="6" height="4" rx="2" /><path d="M9 17v-5" /><path d="M12 17v-1" /><path d="M15 17v-3" /></svg>
                    Генерация ОПиУ
                </h3>
                <div class="card-actions">
                    <a href="#" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-generate-pl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" /><path d="M9 17h6" /><path d="M12 14v3" /></svg>
                        Сгенерировать отчёт
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="text-muted">
                    Генерация документа ОПиУ (Отчёт о прибылях и убытках) на основе данных продаж, возвратов и расходов маркетплейса.
                    Необработанные записи будут агрегированы по категориям и преобразованы в строки отчёта.
                </div>
                {% if connections is not empty %}
                    <div class="mt-2">
                        <small class="text-muted">
                            Доступные маркетплейсы:
                            {% for connection in connections %}
                                <span class="badge bg-azure-lt me-1">{{ connection.marketplace.displayName }}</span>
                            {% endfor %}
                        </small>
                    </div>
                {% endif %}
            </div>
        </div>

        {# История синхронизаций #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">История синхронизаций</h3>
            </div>
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                    <tr>
                        <th>Маркетплейс</th>
                        <th>Тип документа</th>
                        <th>Период</th>
                        <th>Записей</th>
                        <th>Создано</th>
                        <th>Пропущено</th>
                        <th>Дата</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if rawDocuments is empty %}
                        <tr>
                            <td colspan="8" class="text-center text-muted">Нет данных</td>
                        </tr>
                    {% else %}
                        {% for doc in rawDocuments %}
                            <tr>
                                <td><span class="badge bg-azure text-azure-fg">{{ doc.marketplace.displayName }}</span></td>
                                <td>{{ doc.documentType }}</td>
                                <td><small>{{ doc.periodFrom|date('d.m.Y') }} — {{ doc.periodTo|date('d.m.Y') }}</small></td>
                                <td>{{ doc.recordsCount }}</td>
                                <td><span class="badge bg-success text-success-fg">{{ doc.recordsCreated }}</span></td>
                                <td><span class="badge bg-secondary">{{ doc.recordsSkipped }}</span></td>
                                <td><small>{{ doc.syncedAt|date('d.m.Y H:i') }}</small></td>
                                <td class="text-end">
                                    <div class="btn-list">
                                        <a href="{{ path('marketplace_raw_view', {id: doc.id}) }}" class="btn btn-sm btn-ghost-primary" target="_blank">JSON</a>
                                        {% if doc.documentType == 'sales_report' %}
                                            <a href="{{ path('marketplace_raw_process_sales', {id: doc.id}) }}" class="btn btn-sm btn-success">Продажи</a>
                                            <a href="{{ path('marketplace_raw_process_returns', {id: doc.id}) }}" class="btn btn-sm btn-warning">Возвраты</a>
                                            <a href="{{ path('marketplace_raw_process_costs', {id: doc.id}) }}" class="btn btn-sm btn-purple">Затраты</a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {# Строка 129-135 — ПРОВЕРЬ что этот блок совпадает с оригиналом #}
                            {% if doc.unprocessedCostsCount is defined and doc.unprocessedCostsCount > 0 %}
                                <tr class="bg-warning-lt">
                                    <td colspan="8">
                                        <div class="d-flex align-items-center">
                                            <div>
                                                <strong>Нераспознано затрат: {{ doc.unprocessedCostsCount }}</strong>
                                                <div class="text-muted small mt-1">
                                                    {% for type, count in doc.unprocessedCostTypes %}
                                                        <span class="badge bg-warning-lt me-1">{{ type }} ({{ count }})</span>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                            <div class="ms-auto">
                                                <a href="{{ path('marketplace_raw_process_costs', {id: doc.id}) }}" class="btn btn-sm btn-warning">
                                                    Обработать повторно
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
{% endblock %}

{% block modals %}
    {# Modal: Добавить подключение #}
    <div class="modal modal-blur fade" id="modal-add-connection" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="{{ path('marketplace_connection_create') }}">
                    <div class="modal-header">
                        <h5 class="modal-title">Новое подключение</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Маркетплейс</label>
                            <select name="marketplace" id="connection-marketplace" class="form-select" required>
                                <option value="">Выберите маркетплейс</option>
                                {% for marketplace in availableMarketplaces %}
                                    <option value="{{ marketplace.value }}">{{ marketplace.displayName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3" id="field-client-id" style="display: none;">
                            <label class="form-label required">Client-Id</label>
                            <input type="text" name="client_id" id="input-client-id" class="form-control" placeholder="Например: 123456">
                            <small class="form-hint">Найдите Client-Id в личном кабинете Ozon → Настройки → API ключи</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">API ключ</label>
                            <input type="text" name="api_key" class="form-control" placeholder="Введите API ключ" required>
                            <small class="form-hint">Получите API ключ в личном кабинете маркетплейса</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">Добавить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal: Синхронизация за период #}
    <div class="modal modal-blur fade" id="modal-sync-period" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="get" id="form-sync-period" action="">
                    <div class="modal-header">
                        <h5 class="modal-title">Синхронизировать за период</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Дата начала</label>
                            <input type="date" name="date_from" class="form-control" required
                                   value="{{ 'now'|date_modify('-7 days')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Дата окончания</label>
                            <input type="date" name="date_to" class="form-control" required
                                   value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="text-muted small">Максимальный период — 31 день.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">Синхронизировать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ============================================================= #}
    {# Modal: Генерация ОПиУ — НОВОЕ                                  #}
    {# ============================================================= #}
    <div class="modal modal-blur fade" id="modal-generate-pl" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="{{ path('marketplace_pl_generate') }}" id="form-generate-pl">
                    <div class="modal-header">
                        <h5 class="modal-title">Генерация ОПиУ</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Маркетплейс</label>
                            <select name="marketplace" class="form-select" required>
                                <option value="">Выберите маркетплейс</option>
                                {% for connection in connections %}
                                    <option value="{{ connection.marketplace.value }}">{{ connection.marketplace.displayName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Период — начало</label>
                            <input type="date" name="period_from" class="form-control" required
                                   value="{{ 'now'|date_modify('first day of this month')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Период — конец</label>
                            <input type="date" name="period_to" class="form-control" required
                                   value="{{ 'now'|date_modify('last day of this month')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Поток данных</label>
                            <div class="form-selectgroup">
                                <label class="form-selectgroup-item">
                                    <input type="radio" name="stream_choice" value="all" class="form-selectgroup-input" checked>
                                    <span class="form-selectgroup-label">Все (выручка + расходы)</span>
                                </label>
                                <label class="form-selectgroup-item">
                                    <input type="radio" name="stream_choice" value="revenue" class="form-selectgroup-input">
                                    <span class="form-selectgroup-label">Выручка и возвраты</span>
                                </label>
                                <label class="form-selectgroup-item">
                                    <input type="radio" name="stream_choice" value="costs" class="form-selectgroup-input">
                                    <span class="form-selectgroup-label">Расходы МП</span>
                                </label>
                            </div>
                            {# Hidden fields — заполняются JS на основе radio #}
                            <input type="hidden" name="all_streams" id="pl-all-streams" value="1">
                            <input type="hidden" name="stream" id="pl-stream" value="">
                        </div>
                        <div class="alert alert-info mb-0">
                            <div class="d-flex">
                                <div>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="12" r="9" /><line x1="12" y1="8" x2="12.01" y2="8" /><polyline points="11 12 12 12 12 16 13 16" /></svg>
                                </div>
                                <div>
                                    Будут обработаны только записи, у которых ещё нет привязки к документу ОПиУ.
                                    Повторная генерация за тот же период безопасна.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary" id="btn-generate-pl">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10" /></svg>
                            Сгенерировать
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Показ/скрытие поля Client-Id в зависимости от маркетплейса
        document.getElementById('connection-marketplace').addEventListener('change', function () {
            var clientIdField = document.getElementById('field-client-id');
            var clientIdInput = document.getElementById('input-client-id');
            if (this.value === 'ozon') {
                clientIdField.style.display = '';
                clientIdInput.required = true;
            } else {
                clientIdField.style.display = 'none';
                clientIdInput.required = false;
                clientIdInput.value = '';
            }
        });

        // Sync period modal
        document.getElementById('modal-sync-period').addEventListener('show.bs.modal', function (event) {
            var connectionId = event.relatedTarget.getAttribute('data-connection-id');
            document.getElementById('form-sync-period').action = '/marketplace/connection/' + connectionId + '/sync-period';
        });

        // Блокировка кнопки при отправке формы синхронизации
        document.getElementById('form-sync-period').addEventListener('submit', function () {
            var submitBtn = this.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Синхронизация...';
        });

        // ============================================================
        // Генерация ОПиУ — НОВЫЙ JS
        // ============================================================

        // Radio → hidden fields (all_streams / stream)
        document.querySelectorAll('input[name="stream_choice"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                var allStreams = document.getElementById('pl-all-streams');
                var stream = document.getElementById('pl-stream');

                if (this.value === 'all') {
                    allStreams.value = '1';
                    stream.value = '';
                } else {
                    allStreams.value = '0';
                    stream.value = this.value;
                }
            });
        });

        // Блокировка кнопки при генерации ОПиУ
        document.getElementById('form-generate-pl').addEventListener('submit', function () {
            var btn = document.getElementById('btn-generate-pl');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Генерация...';
        });

        // ============================================================
        // Опрос статуса первичной загрузки
        // ============================================================
        (function () {
            var pendingNodes = document.querySelectorAll('[data-status-url][data-synced="0"]');
            if (pendingNodes.length === 0) return;

            pendingNodes.forEach(function (node) {
                var url      = node.dataset.statusUrl;
                var interval = setInterval(function () {
                    fetch(url, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (data.status === 'synced') {
                                clearInterval(interval);
                                node.innerHTML = '<small>Последняя синхронизация: ' + data.lastSyncAt + '</small>';
                            } else if (data.status === 'error') {
                                clearInterval(interval);
                                node.innerHTML = '<small class="text-danger">Ошибка: ' + (data.lastSyncError ?? '') + '</small>';
                            }
                            // pending — ничего не меняем, ждём следующего тика
                        })
                        .catch(function () { /* сеть недоступна — продолжаем опрос */ });
                }, 15000);
            });
        })();
    </script>
{% endblock %}
