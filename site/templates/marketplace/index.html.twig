{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'marketplace' %}

{% block tab_content %}
    <div class="p-3">

        {# Подключения #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">Активные подключения</h3>
                <div class="card-actions">
                    <a href="#" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add-connection">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Добавить подключение
                    </a>
                </div>
            </div>
            <div class="card-body">
                {% if connections is empty %}
                    <div class="empty">
                        <div class="empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="7" cy="18" r="2" /><circle cx="7" cy="6" r="2" /><circle cx="17" cy="12" r="2" /><line x1="7" y1="8" x2="7" y2="16" /><path d="M7 8a4 4 0 0 0 4 4h4" /></svg>
                        </div>
                        <p class="empty-title">Нет активных подключений</p>
                        <p class="empty-subtitle text-muted">Добавьте подключение к маркетплейсу для начала работы</p>
                    </div>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for connection in connections %}
                            <div class="list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <span class="avatar">{{ connection.marketplace.value|slice(0,2)|upper }}</span>
                                    </div>
                                    <div class="col text-truncate">
                                        <div class="text-reset d-block">{{ connection.marketplace.displayName }}</div>
                                        <div class="d-block text-muted text-truncate mt-n1">
                                            {% if connection.clientId %}
                                                Client-Id: {{ connection.clientId }} &middot;
                                            {% endif %}
                                            API Key: {{ connection.apiKey|slice(0, 20) }}***
                                        </div>
                                        <div class="d-block text-muted mt-1"
                                             data-connection-id="{{ connection.id }}"
                                             data-status-url="{{ path('marketplace_connection_status', {id: connection.id}) }}"
                                             data-synced="{{ connection.lastSyncAt ? '1' : '0' }}"
                                             id="connection-status-{{ connection.id }}">
                                            {% if connection.lastSyncAt %}
                                                <small>Последняя синхронизация: {{ connection.lastSyncAt|date('d.m.Y H:i') }}</small>
                                            {% else %}
                                                <small class="text-warning">
                                                    <span class="spinner-border spinner-border-sm me-1" style="width:.7rem;height:.7rem"></span>
                                                    Первичная загрузка данных...
                                                </small>
                                            {% endif %}
                                        </div>
                                        {% if connection.lastSyncError %}
                                            <div class="text-danger mt-1">
                                                <small>Ошибка: {{ connection.lastSyncError|slice(0, 100) }}</small>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-auto">
                                        <span class="badge bg-{{ connection.isActive ? 'success' : 'secondary' }}">
                                            {{ connection.isActive ? 'Активно' : 'Неактивно' }}
                                        </span>
                                    </div>
                                    <div class="col-auto">
                                        <div class="btn-list">
                                            <a href="{{ path('marketplace_connection_edit', {id: connection.id}) }}" class="btn btn-sm btn-outline-secondary">Настройки</a>
                                            <a href="{{ path('marketplace_connection_test', {id: connection.id}) }}" class="btn btn-sm btn-outline-info">Проверить</a>
                                            <a href="{{ path('marketplace_connection_sync', {id: connection.id}) }}" class="btn btn-sm btn-primary">Синхронизировать</a>
                                            <a href="#" class="btn btn-sm btn-outline-primary"
                                               data-bs-toggle="modal"
                                               data-bs-target="#modal-sync-period"
                                               data-connection-id="{{ connection.id }}">За период</a>
                                            {% if connection.marketplace.value == 'ozon' %}
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-teal"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modal-sync-realization"
                                                        data-connection-id="{{ connection.id }}"
                                                        data-action="{{ path('marketplace_connection_sync_realization', {id: connection.id}) }}">
                                                    Реализация
                                                </button>
                                            {% endif %}
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modal-reprocess"
                                                    data-marketplace="{{ connection.marketplace.value }}">
                                                Переобработать
                                            </button>
                                            <form method="post" action="{{ path('marketplace_connection_toggle', {id: connection.id}) }}" style="display:inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ connection.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                    {{ connection.isActive ? 'Деактивировать' : 'Активировать' }}
                                                </button>
                                            </form>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modal-delete-connection"
                                                    data-connection-id="{{ connection.id }}"
                                                    data-action="{{ path('marketplace_connection_delete', {id: connection.id}) }}"
                                                    data-token="{{ csrf_token('delete' ~ connection.id) }}">
                                                Удалить
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# История синхронизаций #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">История синхронизаций</h3>
                <div class="card-actions">
                    <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#bulkProcessModal">
                        Обработать месяц
                    </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table card-table table-vcenter">
                    <thead>
                    <tr>
                        <th>Маркетплейс</th>
                        <th>Тип документа</th>
                        <th>Период</th>
                        <th>Записей</th>
                        <th>Создано</th>
                        <th>Пропущено</th>
                        <th>Дата</th>
                        <th>Обработка</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if rawDocumentsPager.nbResults == 0 %}
                        <tr>
                            <td colspan="9" class="text-center text-muted">Нет данных</td>
                        </tr>
                    {% else %}
                        {% for doc in rawDocumentsPager.currentPageResults %}
                            <tr>
                                <td><span class="badge bg-azure text-azure-fg">{{ doc.marketplace.displayName }}</span></td>
                                <td>{{ doc.documentType }}</td>
                                <td><small>{{ doc.periodFrom|date('d.m.Y') }} — {{ doc.periodTo|date('d.m.Y') }}</small></td>
                                <td>{{ doc.recordsCount }}</td>
                                <td><span class="badge bg-success text-success-fg">{{ doc.recordsCreated }}</span></td>
                                <td><span class="badge bg-secondary">{{ doc.recordsSkipped }}</span></td>
                                <td><small>{{ doc.syncedAt|date('d.m.Y H:i') }}</small></td>
                                <td>
                                    {% if doc.processingStatus is not null %}
                                        {% if doc.processingStatus.value == 'completed' %}
                                            <span class="badge bg-success">Готово</span>
                                        {% elseif doc.processingStatus.value == 'running' %}
                                            <span class="badge bg-info">В работе</span>
                                        {% elseif doc.processingStatus.value == 'failed' %}
                                            <span class="badge bg-danger">Ошибка</span>
                                        {% elseif doc.processingStatus.value == 'pending' %}
                                            <span class="badge bg-secondary">Очередь</span>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="btn-list">
                                        <a href="{{ path('marketplace_raw_view', {id: doc.id}) }}" class="btn btn-sm btn-ghost-primary" target="_blank">JSON</a>
                                        {% if doc.documentType == 'sales_report' %}
                                            <a href="{{ path('marketplace_raw_process_sales', {id: doc.id}) }}" class="btn btn-sm btn-success">Продажи</a>
                                            <a href="{{ path('marketplace_raw_process_returns', {id: doc.id}) }}" class="btn btn-sm btn-warning">Возвраты</a>
                                            <a href="{{ path('marketplace_raw_process_costs', {id: doc.id}) }}" class="btn btn-sm btn-purple">Затраты</a>
                                        {% elseif doc.documentType == 'realization' %}
                                            <button type="button"
                                                    class="btn btn-sm btn-teal"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modal-apply-realization"
                                                    data-action="{{ path('marketplace_raw_process_realization', {id: doc.id}) }}">
                                                Применить выручку
                                            </button>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% if doc.unprocessedCostsCount is defined and doc.unprocessedCostsCount > 0 %}
                                <tr class="bg-warning-lt">
                                    <td colspan="9">
                                        <div class="d-flex align-items-center">
                                            <div>
                                                <strong>Нераспознано затрат: {{ doc.unprocessedCostsCount }}</strong>
                                                <div class="text-muted small mt-1">
                                                    {% for type, count in doc.unprocessedCostTypes %}
                                                        <span class="badge bg-warning-lt me-1">{{ type }} ({{ count }})</span>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                            <div class="ms-auto">
                                                <a href="{{ path('marketplace_raw_process_costs', {id: doc.id}) }}" class="btn btn-sm btn-warning">
                                                    Обработать повторно
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>
            {% if rawDocumentsPager.haveToPaginate %}
                <div class="card-footer d-flex align-items-center">
                    {% include 'partials/_pagerfanta.html.twig' with {
                        'pager': rawDocumentsPager
                    } %}
                </div>
            {% endif %}
        </div>

    </div>
{% endblock %}

{% block modals %}
    {# Modal: Добавить подключение #}
    <div class="modal modal-blur fade" id="modal-add-connection" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="{{ path('marketplace_connection_create') }}">
                    <div class="modal-header">
                        <h5 class="modal-title">Новое подключение</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Маркетплейс</label>
                            <select name="marketplace" id="connection-marketplace" class="form-select" required>
                                <option value="">Выберите маркетплейс</option>
                                {% for marketplace in availableMarketplaces %}
                                    <option value="{{ marketplace.value }}">{{ marketplace.displayName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3" id="field-client-id" style="display: none;">
                            <label class="form-label required">Client-Id</label>
                            <input type="text" name="client_id" id="input-client-id" class="form-control" placeholder="Например: 123456">
                            <small class="form-hint">Найдите Client-Id в личном кабинете Ozon → Настройки → API ключи</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">API ключ</label>
                            <input type="text" name="api_key" class="form-control" placeholder="Введите API ключ" required>
                            <small class="form-hint">Получите API ключ в личном кабинете маркетплейса</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">Добавить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal: Синхронизация за период #}
    <div class="modal modal-blur fade" id="modal-sync-period" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="get" id="form-sync-period" action="">
                    <div class="modal-header">
                        <h5 class="modal-title">Синхронизировать за период</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Дата начала</label>
                            <input type="date" name="date_from" class="form-control" required
                                   value="{{ 'now'|date_modify('-7 days')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Дата окончания</label>
                            <input type="date" name="date_to" class="form-control" required
                                   value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="text-muted small">Максимальный период — 31 день.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">Синхронизировать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal: Подтверждение загрузки реализации Ozon #}
    <div class="modal modal-blur fade" id="modal-sync-realization" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="modal-title">Загрузка реализации Ozon</div>
                    <div class="text-muted mt-2">
                        Если данных ещё нет — будут загружены все месяцы с начала года.<br>
                        Если данные уже есть — будет обновлён прошлый месяц.
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="w-100">
                        <div class="row">
                            <div class="col">
                                <button type="button" class="btn w-100" data-bs-dismiss="modal">Отмена</button>
                            </div>
                            <div class="col">
                                <form method="post" id="form-sync-realization" action="">
                                    <button type="submit" class="btn btn-teal w-100">Запустить</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Modal: Переобработка за период #}
    <div class="modal modal-blur fade" id="modal-reprocess" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="{{ path('marketplace_reprocess') }}" id="form-reprocess">
                    <div class="modal-header">
                        <h5 class="modal-title">Переобработка данных за период</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="marketplace" id="reprocess-marketplace">
                        <div class="mb-3">
                            <label class="form-label required">Период — начало</label>
                            <input type="date" name="period_from" class="form-control" required
                                   value="{{ 'now'|date_modify('first day of last month')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Период — конец</label>
                            <input type="date" name="period_to" class="form-control" required
                                   value="{{ 'now'|date_modify('last day of last month')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Тип документов</label>
                            <select name="type" class="form-select">
                                <option value="all">Все (продажи + возвраты + затраты + реализация)</option>
                                <option value="sales_report">Только продажи / возвраты / затраты</option>
                                <option value="realization">Только реализация Ozon</option>
                            </select>
                        </div>
                        <div class="alert alert-warning mb-0">
                            <div class="d-flex">
                                <div>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v4" /><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z" /><path d="M12 16h.01" /></svg>
                                </div>
                                <div>
                                    Переобработка обновит существующие записи новыми данными.
                                    Маркировка закрытия месяца <strong>не снимается</strong> — для этого используйте «Переоткрыть» в закрытии месяца.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-warning" id="btn-reprocess">
                            Переобработать
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal: Подтверждение удаления подключения #}
    <div class="modal modal-blur fade" id="modal-delete-connection" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="modal-title">Удалить подключение?</div>
                    <div class="text-muted mt-2">
                        Все данные синхронизации для этого подключения будут удалены. Это действие необратимо.
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="w-100">
                        <div class="row">
                            <div class="col">
                                <button type="button" class="btn w-100" data-bs-dismiss="modal">Отмена</button>
                            </div>
                            <div class="col">
                                <form method="post" id="form-delete-connection" action="">
                                    <input type="hidden" name="_token" id="delete-connection-token" value="">
                                    <button type="submit" class="btn btn-danger w-100">Удалить</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Modal: Подтверждение применения выручки из реализации #}
    <div class="modal modal-blur fade" id="modal-apply-realization" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="modal-title">Применить выручку?</div>
                    <div class="text-muted mt-2">
                        Значения выручки в существующих продажах будут обновлены данными из отчёта реализации Ozon.
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="w-100">
                        <div class="row">
                            <div class="col">
                                <button type="button" class="btn w-100" data-bs-dismiss="modal">Отмена</button>
                            </div>
                            <div class="col">
                                <a href="" id="btn-apply-realization" class="btn btn-teal w-100">Применить</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Modal: Пакетная обработка за месяц #}
    <div class="modal modal-blur fade" id="bulkProcessModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Обработать месяц</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label required">Маркетплейс</label>
                        <select id="bulk-marketplace" class="form-select" required>
                            <option value="">Выберите маркетплейс</option>
                            {% for marketplace in availableMarketplaces %}
                                <option value="{{ marketplace.value }}">{{ marketplace.displayName }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label required">Месяц</label>
                        <input type="month" id="bulk-month" class="form-control" required
                               value="{{ 'now'|date_modify('first day of last month')|date('Y-m') }}">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-warning" id="bulk-process-btn">
                        Запустить обработку
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Показ/скрытие поля Client-Id в зависимости от маркетплейса
        document.getElementById('connection-marketplace').addEventListener('change', function () {
            var clientIdField = document.getElementById('field-client-id');
            var clientIdInput = document.getElementById('input-client-id');
            if (this.value === 'ozon') {
                clientIdField.style.display = '';
                clientIdInput.required = true;
            } else {
                clientIdField.style.display = 'none';
                clientIdInput.required = false;
                clientIdInput.value = '';
            }
        });

        // Sync period modal — подставляем action с connectionId
        document.getElementById('modal-sync-period').addEventListener('show.bs.modal', function (event) {
            var connectionId = event.relatedTarget.getAttribute('data-connection-id');
            document.getElementById('form-sync-period').action = '/marketplace/connection/' + connectionId + '/sync-period';
        });

        // Блокировка кнопки при отправке формы синхронизации за период
        document.getElementById('form-sync-period').addEventListener('submit', function () {
            var submitBtn = this.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Синхронизация...';
        });

        // modal-reprocess — подставляем marketplace из data-marketplace кнопки
        document.getElementById('modal-reprocess').addEventListener('show.bs.modal', function (event) {
            document.getElementById('reprocess-marketplace').value = event.relatedTarget.getAttribute('data-marketplace');
        });

        // Блокировка кнопки при отправке формы переобработки
        document.getElementById('form-reprocess').addEventListener('submit', function () {
            var btn = document.getElementById('btn-reprocess');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Обработка...';
            // Закрываем модал чтобы пользователь видел страницу во время обработки
            var modal = bootstrap.Modal.getInstance(document.getElementById('modal-reprocess'));
            if (modal) { modal.hide(); }
        });

        // modal-sync-realization — подставляем action из data-action кнопки
        document.getElementById('modal-sync-realization').addEventListener('show.bs.modal', function (event) {
            document.getElementById('form-sync-realization').action = event.relatedTarget.getAttribute('data-action');
        });

        // modal-delete-connection — подставляем action из data-action кнопки
        document.getElementById('modal-delete-connection').addEventListener('show.bs.modal', function (event) {
            document.getElementById('form-delete-connection').action = event.relatedTarget.getAttribute('data-action');
            document.getElementById('delete-connection-token').value = event.relatedTarget.getAttribute('data-token');
        });

        // modal-apply-realization — подставляем href из data-action кнопки
        document.getElementById('modal-apply-realization').addEventListener('show.bs.modal', function (event) {
            document.getElementById('btn-apply-realization').href = event.relatedTarget.getAttribute('data-action');
        });

        // Пакетная обработка месяца
        document.getElementById('bulk-process-btn').addEventListener('click', function () {
            var marketplace = document.getElementById('bulk-marketplace').value;
            var monthVal    = document.getElementById('bulk-month').value;

            if (!marketplace || !monthVal) {
                alert('Выберите маркетплейс и месяц');
                return;
            }

            var parts = monthVal.split('-');
            var year  = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10);

            var btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Запуск...';

            fetch('{{ path('marketplace_bulk_process') }}', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                body: JSON.stringify({marketplace: marketplace, year: year, month: month})
            })
                .then(function (r) { return r.json().then(function (data) { return {ok: r.ok, data: data}; }); })
                .then(function (res) {
                    var modal = bootstrap.Modal.getInstance(document.getElementById('bulkProcessModal'));
                    if (modal) { modal.hide(); }
                    if (res.ok) {
                        alert('Запущено документов: ' + res.data.dispatched);
                        window.location.reload();
                    } else {
                        alert('Ошибка: ' + (res.data.error ?? 'Неизвестная ошибка'));
                        btn.disabled = false;
                        btn.innerHTML = 'Запустить обработку';
                    }
                })
                .catch(function () {
                    alert('Ошибка сети. Попробуйте ещё раз.');
                    btn.disabled = false;
                    btn.innerHTML = 'Запустить обработку';
                });
        });

        // Опрос статуса первичной загрузки
        (function () {
            var pendingNodes = document.querySelectorAll('[data-status-url][data-synced="0"]');
            if (pendingNodes.length === 0) return;

            pendingNodes.forEach(function (node) {
                var url      = node.dataset.statusUrl;
                var interval = setInterval(function () {
                    fetch(url, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (data.status === 'synced') {
                                clearInterval(interval);
                                node.innerHTML = '<small>Последняя синхронизация: ' + data.lastSyncAt + '</small>';
                            } else if (data.status === 'error') {
                                clearInterval(interval);
                                node.innerHTML = '<small class="text-danger">Ошибка: ' + (data.lastSyncError ?? '') + '</small>';
                            }
                        })
                        .catch(function () { /* сеть недоступна — продолжаем опрос */ });
                }, 15000);
            });
        })();
    </script>
{% endblock %}
