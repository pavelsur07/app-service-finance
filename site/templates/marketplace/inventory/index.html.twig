{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'inventory' %}

{% block tab_content %}
    <div class="p-3">

        <div class="mb-3 d-flex align-items-center gap-2">
            <select class="form-select w-auto"
                    onchange="window.location.href = this.value">
                <option value="{{ path('marketplace_inventory_index') }}"
                    {{ marketplace is null ? 'selected' : '' }}>
                    Все маркетплейсы
                </option>
                <option value="{{ path('marketplace_inventory_index', {marketplace: 'wildberries'}) }}"
                    {{ marketplace == 'wildberries' ? 'selected' : '' }}>
                    Wildberries
                </option>
                <option value="{{ path('marketplace_inventory_index', {marketplace: 'ozon'}) }}"
                    {{ marketplace == 'ozon' ? 'selected' : '' }}>
                    Ozon
                </option>
            </select>

            <button type="button"
                    class="btn btn-sm btn-outline-secondary ms-auto"
                    data-bs-toggle="modal"
                    data-bs-target="#modal-import-cost">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24"
                     viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"/>
                    <path d="M7 11l5 5l5 -5"/>
                    <path d="M12 4l0 12"/>
                </svg>
                Загрузить из файла
            </button>

            <form method="post" action="{{ path('marketplace_inventory_sync_barcodes') }}">
                <button type="submit" class="btn btn-sm btn-outline-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24"
                         viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/>
                        <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>
                    </svg>
                    Синхронизировать баркоды Ozon
                </button>
            </form>
        </div>


        {# Виджет статуса последних задач #}
        {% if job_logs is not empty %}
            <div class="mb-3 d-flex flex-column gap-2">
                {% for job_type, log in job_logs %}
                    <div class="alert {{ log.hasErrors ? 'alert-warning' : (log.status.value == 'running' ? 'alert-info' : 'alert-success') }} alert-dismissible mb-0 py-2">
                        <div class="d-flex align-items-center gap-2">
                            {% if log.status.value == 'running' %}
                                <div class="spinner-border spinner-border-sm" role="status"></div>
                            {% elseif log.hasErrors %}
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v4m0 4h.01"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/></svg>
                            {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10"/></svg>
                            {% endif %}

                            <span class="fw-medium">{{ log.jobType.label }}</span>
                            <span class="text-muted small">
                            {{ log.startedAt|date('d.m.Y H:i') }}
                                {% if log.finishedAt %}— {{ log.finishedAt|date('H:i:ss') }}{% endif %}
                        </span>

                            {% if log.summary %}
                                <span class="small ms-1">
                                {% if log.status.value == 'failed' %}
                                    Ошибка: {{ log.summary.error ?? 'неизвестная ошибка' }}
                                {% elseif log.jobType.value == 'barcode_sync_ozon' %}
                                    создано {{ log.summary.barcodes_created ?? 0 }},
                                    пропущено {{ log.summary.barcodes_skipped ?? 0 }},
                                    не найдено в API: {{ log.summary.errors ?? 0 }}
                                {% elseif log.jobType.value == 'cost_price_import' %}
                                    импортировано {{ log.summary.imported ?? 0 }},
                                    пропущено {{ log.summary.skipped ?? 0 }},
                                    ошибок {{ log.summary.errors ?? 0 }}
                                    ({{ log.summary.file ?? '' }}, {{ log.summary.marketplace ?? '' }})
                                {% endif %}
                            </span>
                            {% endif %}

                            {% if log.details is not empty %}
                                <button type="button" class="btn btn-sm btn-link p-0 ms-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modal-job-details-{{ loop.index }}">
                                    показать детали
                                </button>
                            {% endif %}
                        </div>
                    </div>

                    {# Модал с деталями ошибок #}
                    {% if log.details is not empty %}
                        <div class="modal modal-blur fade" id="modal-job-details-{{ loop.index }}" tabindex="-1" role="dialog">
                            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">{{ log.jobType.label }} — детали</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <table class="table table-sm table-vcenter">
                                            <thead>
                                            <tr>
                                                {% if log.jobType.value == 'barcode_sync_ozon' %}
                                                    <th>SKU</th>
                                                    <th>Название</th>
                                                {% endif %}
                                                <th>Причина</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% for detail in log.details %}
                                                <tr>
                                                    {% if log.jobType.value == 'barcode_sync_ozon' %}
                                                        <td><span class="text-muted small">{{ detail.sku ?? '—' }}</span></td>
                                                        <td>{{ detail.name ?? '—' }}</td>
                                                    {% endif %}
                                                    <td><span class="text-danger small">{{ detail.reason ?? '—' }}</span></td>
                                                </tr>
                                            {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-link" data-bs-dismiss="modal">Закрыть</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}

        <div class="card">
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                    <tr>
                        <th>Листинг / Товар</th>
                        <th>Маркетплейс</th>
                        <th>SKU</th>
                        <th>Артикул продавца</th>
                        <th>Баркод</th>
                        <th class="text-end">Себестоимость</th>
                        <th>Действует с</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in pager.currentPageResults %}
                        <tr>
                            <td>
                                {% if row.product_name is not null %}
                                    <div class="fw-medium">{{ row.product_name }}</div>
                                    <div class="text-muted small">{{ row.product_sku }}</div>
                                {% else %}
                                    <div class="fw-medium">{{ row.listing_name ?? row.marketplace_sku }}</div>
                                    <div class="text-muted small">
                                        <span class="badge bg-yellow-lt">Без привязки к товару</span>
                                    </div>
                                {% endif %}
                            </td>
                            <td><span class="badge bg-azure-lt">{{ row.marketplace|upper }}</span></td>
                            <td><span class="text-muted small">{{ row.marketplace_sku }}</span></td>
                            <td><span class="text-muted small">{{ row.supplier_sku ?? '—' }}</span></td>
                            <td>
                                {% if row.barcode %}
                                    <span class="text-muted small">{{ row.barcode }}</span>
                                {% elseif row.marketplace == 'ozon' %}
                                    <form method="post" action="{{ path('marketplace_inventory_sync_barcode_single', {id: row.listing_id}) }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-ghost-secondary py-0 px-1" title="Получить баркод из Ozon API">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/>
                                                <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>
                                            </svg>
                                            Получить
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if row.cost_price is not null %}
                                    <span class="fw-medium">
                                        {{ row.cost_price|number_format(2, '.', ' ') }} {{ row.cost_currency }}
                                    </span>
                                {% else %}
                                    <span class="text-danger small">Не задана</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if row.cost_from is not null %}
                                    <span class="text-muted small">{{ row.cost_from|date('d.m.Y') }}</span>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <div class="btn-list">
                                    <a href="{{ path('marketplace_inventory_history', {id: row.listing_id}) }}"
                                       class="btn btn-sm btn-outline-secondary">История</a>
                                    <button type="button"
                                            class="btn btn-sm {{ row.cost_price is null ? 'btn-primary' : 'btn-outline-primary' }}"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modal-set-cost"
                                            data-action="{{ path('marketplace_inventory_set_cost', {id: row.listing_id}) }}"
                                            data-listing-name="{{ row.product_name ?? row.listing_name ?? row.marketplace_sku }} / {{ row.marketplace|upper }}">
                                        {{ row.cost_price is null ? 'Добавить' : 'Изменить' }}
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                {% if marketplace is not null %}
                                    Нет листингов для выбранного маркетплейса.
                                {% else %}
                                    Нет листингов. Добавьте подключение к маркетплейсу и запустите синхронизацию.
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if pager.haveToPaginate %}
                <div class="card-footer d-flex align-items-center">
                    {{ include('partials/_pagerfanta.html.twig', {pager: pager}) }}
                </div>
            {% endif %}
        </div>
    </div>

    {# Modal: Установить себестоимость вручную #}
    <div class="modal modal-blur fade" id="modal-set-cost" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" id="form-set-cost" action="">
                    <div class="modal-header">
                        <h5 class="modal-title">Себестоимость</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="text-muted small mb-3" id="modal-set-cost-name"></div>
                        <div class="mb-3">
                            <label class="form-label required">Сумма, ₽</label>
                            <input type="number" name="price_amount" class="form-control"
                                   step="0.01" min="0" placeholder="850.00" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Действует с</label>
                            <input type="date" name="effective_from" class="form-control"
                                   value="{{ 'now'|date('Y-m-d') }}" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Примечание</label>
                            <input type="text" name="note" class="form-control"
                                   placeholder="Новая партия, пересмотр цен...">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-link link-secondary me-auto" data-bs-dismiss="modal">
                            Отмена
                        </button>
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal: Загрузить себестоимость из файла #}
    <div class="modal modal-blur fade" id="modal-import-cost" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post"
                      action="{{ path('marketplace_inventory_import_cost_price') }}"
                      enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title">Загрузить себестоимость из файла</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Маркетплейс</label>
                            <select name="marketplace" class="form-select" required>
                                <option value="">— выберите —</option>
                                <option value="ozon" {{ marketplace == 'ozon' ? 'selected' : '' }}>OZON</option>
                                <option value="wildberries" {{ marketplace == 'wildberries' ? 'selected' : '' }}>WILDBERRIES</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Дата действия себестоимости</label>
                            <input type="date" name="effective_from" class="form-control"
                                   value="{{ 'now'|date('Y-m-d') }}" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Файл (xls, xlsx)</label>
                            <input type="file" name="cost_file" class="form-control"
                                   accept=".xls,.xlsx" required>
                        </div>
                        <div class="alert alert-info mb-0">
                            <div class="small">
                                <strong>Формат файла:</strong><br>
                                Колонка A — Баркод товара<br>
                                Колонка B — Себестоимость (число, напр. 850.00)<br>
                                Строка с заголовками пропускается автоматически.<br>
                                <span class="text-muted">Цена будет установлена только для листингов выбранного маркетплейса.</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-link link-secondary me-auto" data-bs-dismiss="modal">
                            Отмена
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24"
                                 viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M5 12l5 5l10 -10"/>
                            </svg>
                            Запустить импорт
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('modal-set-cost').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('form-set-cost').action = btn.getAttribute('data-action');
            document.getElementById('modal-set-cost-name').textContent = btn.getAttribute('data-listing-name');
        });
    </script>
{% endblock %}
