{#{% extends 'admin/layout.html.twig' %}#}

{% block title %}Неизвестные затраты — Маркетплейсы{% endblock %}

{% block content %}
    <div class="container-xl">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">
                        Неизвестные затраты
                        {% if unresolved_count > 0 %}
                            <span class="badge bg-danger ms-2">{{ unresolved_count }}</span>
                        {% endif %}
                    </h2>
                    <div class="text-muted mt-1">
                        Service names не найденные в OzonServiceCategoryMap.
                        После добавления в маппинг — отметить как решённое.
                    </div>
                </div>
                <div class="col-auto">
                    <a href="{{ path('admin_marketplace_mapping_errors', {all: show_all ? 0 : 1}) }}"
                       class="btn btn-outline-secondary btn-sm">
                        {% if show_all %}Показать только нерешённые{% else %}Показать все{% endif %}
                    </a>
                </div>
            </div>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible">{{ flash }}</div>
        {% endfor %}

        {% if errors is empty %}
            <div class="card">
                <div class="card-body text-center py-5 text-muted">
                    {% if show_all %}
                        Ошибок маппинга нет.
                    {% else %}
                        Нерешённых ошибок нет. 🎉
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-vcenter table-hover card-table">
                        <thead>
                        <tr>
                            <th>Компания</th>
                            <th>Контакт</th>
                            <th>Маркетплейс</th>
                            <th>Период</th>
                            <th>Service name</th>
                            <th>Operation type</th>
                            <th class="text-end">Сумма</th>
                            <th class="text-end">Строк</th>
                            <th>Обнаружено</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for error in errors %}
                            <tr class="{{ error.resolved_at ? 'opacity-50' : '' }}">
                                <td>
                                    <div class="fw-medium">{{ error.company_name }}</div>
                                    <div class="text-muted small">{{ error.company_id|slice(0, 8) }}…</div>
                                </td>
                                <td>
                                    {% if error.contact_email %}
                                        <a href="mailto:{{ error.contact_email }}">{{ error.contact_email }}</a>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge bg-blue-lt text-uppercase">{{ error.marketplace }}</span>
                                </td>
                                <td class="text-nowrap">
                                    {{ ['','Янв','Фев','Мар','Апр','Май','Июн',
                                        'Июл','Авг','Сен','Окт','Ноя','Дек'][error.month] }}
                                    {{ error.year }}
                                </td>
                                <td>
                                    <code class="text-danger fw-medium">{{ error.service_name }}</code>
                                </td>
                                <td>
                                    <span class="text-muted small">{{ error.operation_type ?: '—' }}</span>
                                </td>
                                <td class="text-end">
                                    {{ error.total_amount|number_format(2, '.', ' ') }}
                                </td>
                                <td class="text-end text-muted">
                                    {{ error.rows_count }}
                                </td>
                                <td class="text-nowrap text-muted small">
                                    {{ error.detected_at|date('d.m.Y H:i') }}
                                </td>
                                <td>
                                    {% if error.resolved_at %}
                                        <span class="badge bg-success-lt">Решено</span>
                                        <div class="text-muted small">{{ error.resolved_at|date('d.m.Y') }}</div>
                                    {% else %}
                                        <span class="badge bg-danger-lt">Новое</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        {% if error.sample_raw_json %}
                                            <button type="button"
                                                    class="btn btn-sm btn-ghost-secondary"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#sample-{{ error.id|replace({'-': ''}) }}">
                                                JSON
                                            </button>
                                        {% endif %}

                                        {% if not error.resolved_at %}
                                            <form method="post"
                                                  action="{{ path('admin_marketplace_mapping_error_resolve', {id: error.id}) }}">
                                                <button type="button"
                                                        class="btn btn-sm btn-success"
                                                        onclick="if(confirm('Отметить как решённое?')) this.closest('form').submit()">
                                                    Решено
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    {# Модалки с сырым JSON для диагностики #}
    {% for error in errors %}
        {% if error.sample_raw_json %}
            <div class="modal fade" id="sample-{{ error.id|replace({'-': ''}) }}" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Образец сырых данных — <code>{{ error.service_name }}</code></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <pre class="bg-dark text-white p-3 rounded small" style="max-height:400px;overflow:auto">{{ error.sample_raw_json|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                            <div class="mt-3 text-muted small">
                                <strong>Как добавить в маппинг:</strong><br>
                                Открыть <code>OzonServiceCategoryMap.php</code>, найти подходящую секцию,
                                добавить строку:<br>
                                <code>'{{ error.service_name }}' => 'ozon_CATEGORY_CODE',</code><br>
                                После добавления — переобработать затраты за {{ error.year }}-{{ '%02d'|format(error.month) }}.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endblock %}
