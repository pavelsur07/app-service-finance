{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'cost_pl_mapping' %}

{% block tab_content %}
    <div class="p-3">

        <form method="get" action="{{ path('marketplace_cost_pl_mapping_index') }}"
              class="mb-4 d-flex align-items-end gap-3">
            <div>
                <label class="form-label">Маркетплейс</label>
                <select name="marketplace" class="form-select w-auto" onchange="this.form.submit()">
                    <option value="">Все маркетплейсы</option>
                    {% for mp in available_marketplaces %}
                        <option value="{{ mp.value }}"
                            {{ selected_marketplace == mp.value ? 'selected' : '' }}>
                            {{ mp.value|upper }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </form>

        {% if cost_categories is empty %}
            <div class="alert alert-info">
                Нет категорий затрат. Загрузите затраты из маркетплейса.
            </div>
        {% else %}
            <form method="post" action="{{ path('marketplace_cost_pl_mapping_bulk_save') }}">
                <input type="hidden" name="marketplace" value="{{ selected_marketplace ?? '' }}">

                <div class="card">
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                            <tr>
                                <th>Категория затрат</th>
                                <th>Маркетплейс</th>
                                <th style="min-width: 280px">Категория ОПиУ</th>
                                <th class="text-center">Включить в ОПиУ</th>
                                <th style="width: 80px">Порядок</th>
                                <th style="width: 60px"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for category in cost_categories %}
                                {% set mapping = mappings_indexed[category.id] ?? null %}
                                <tr>
                                    <td>
                                        <div class="fw-medium">{{ category.name }}</div>
                                        {% if category.code %}
                                            <div class="text-muted small">{{ category.code }}</div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge bg-azure-lt">{{ category.marketplace.value|upper }}</span>
                                    </td>
                                    <td>
                                        <select name="mappings[{{ category.id }}][pl_category_id]"
                                                class="form-select form-select-sm">
                                            <option value="">— не задана —</option>
                                            {% for plCat in pl_categories %}
                                                <option value="{{ plCat.id }}"
                                                    {{ (mapping and mapping.plCategoryId == plCat.id) ? 'selected' : '' }}>
                                                    {{ plCat.indentedName }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox"
                                               name="mappings[{{ category.id }}][include_in_pl]"
                                               value="1"
                                               class="form-check-input"
                                            {{ (mapping is null or mapping.includeInPl) ? 'checked' : '' }}>
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="mappings[{{ category.id }}][sort_order]"
                                               value="{{ mapping ? mapping.sortOrder : 0 }}"
                                               class="form-control form-control-sm"
                                               min="0" step="10">
                                    </td>
                                    <td>
                                        {% if not category.isSystem %}
                                            <button type="button"
                                                    class="btn btn-sm btn-ghost-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modal-delete-cost-category"
                                                    data-url="{{ path('marketplace_cost_pl_mapping_delete_category', {id: category.id}) }}"
                                                    data-name="{{ category.name }}"
                                                    data-marketplace="{{ selected_marketplace ?? '' }}">
                                                Удалить
                                            </button>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24"
                                 viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M5 12l5 5l10 -10"/>
                            </svg>
                            Сохранить все маппинги
                        </button>
                    </div>
                </div>
            </form>
        {% endif %}

    </div>

    {# Modal: Удалить категорию затрат #}
    <div class="modal modal-blur fade" id="modal-delete-cost-category" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" id="form-delete-cost-category">
                    <input type="hidden" name="marketplace" id="delete-modal-marketplace" value="">
                    <div class="modal-header">
                        <h5 class="modal-title">Удалить категорию затрат</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-warning" role="alert">
                            <div class="d-flex">
                                <div>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v4" /><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.87l-8.106 -13.536a1.914 1.914 0 0 0 -3.274 0z" /><path d="M12 16h.01" /></svg>
                                </div>
                                <div>
                                    <h4 class="alert-title">Внимание!</h4>
                                    <div class="text-muted">
                                        Категория затрат <strong id="delete-modal-category-name"></strong> будет удалена.
                                        Привязка к категории ОПиУ также будет снята. Продолжить?
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-danger">Удалить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('modal-delete-cost-category').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            var categoryName = btn.getAttribute('data-name');
            var marketplace = btn.getAttribute('data-marketplace');
            var url = btn.getAttribute('data-url');

            document.getElementById('delete-modal-category-name').textContent = '"' + categoryName + '"';
            document.getElementById('delete-modal-marketplace').value = marketplace;
            document.getElementById('form-delete-cost-category').action = url;
        });
    </script>
{% endblock %}
