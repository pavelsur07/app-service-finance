{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'marketplace' %}

{% block tab_content %}
    <div class="container-xl">
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col-auto">
                    <h2 class="page-title">
                        Настройки — {{ connection.marketplace.displayName }}
                    </h2>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <form method="POST" action="{{ path('marketplace_connection_edit', {id: connection.id}) }}">

                    <div class="mb-3">
                        <label class="form-label">Проект ОПиУ</label>
                        <select name="project_direction_id" class="form-select">
                            <option value="">— Без проекта</option>
                            {% for project in project_directions %}
                                <option value="{{ project.id }}"
                                        {% if connection.projectDirectionId == project.id %}selected{% endif %}>
                                    {{ project.indentedName }}
                                </option>
                            {% endfor %}
                        </select>
                        <small class="text-muted">
                            Проект будет проставлен в документ ОПиУ и все его строки при закрытии месяца.
                        </small>
                    </div>

                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                        <a href="{{ path('marketplace_index') }}" class="btn btn-link">Отмена</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
{% endblock %}
