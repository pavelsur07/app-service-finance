{% extends 'marketplace/layout.html.twig' %}

{% set active_tab = 'sales' %}

{% block tab_content %}
    {# Шапка: заголовок + фильтр + кнопка пересчёта #}
    <div class="card-header d-flex align-items-center gap-3">
        <h3 class="card-title me-auto mb-0">Продажи</h3>

        {# Фильтр по маркетплейсу #}
        <form method="get" action="{{ path('marketplace_sales_index') }}" class="d-flex align-items-center gap-2 mb-0">
            <select name="marketplace" class="form-select form-select-sm w-auto"
                    onchange="this.form.submit()">
                <option value="">Все площадки</option>
                {% for mp in available_marketplaces %}
                    <option value="{{ mp.value }}"
                        {{ selected_marketplace == mp.value ? 'selected' : '' }}>
                        {{ mp.value|upper }}
                    </option>
                {% endfor %}
            </select>
        </form>

        <button class="btn btn-sm btn-outline-secondary"
                data-bs-toggle="modal" data-bs-target="#modal-recalculate-cost">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24" viewBox="0 0 24 24"
                 stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/>
                <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>
            </svg>
            Пересчитать себестоимость
        </button>
    </div>

    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
            <tr>
                <th>Дата продажи</th>
                <th>Площадка</th>
                <th>Артикул (SKU)</th>
                <th>Товар</th>
                <th class="text-end">Кол-во</th>
                <th class="text-end">Цена</th>
                <th class="text-end">Выручка</th>
                <th class="text-end">Себес.</th>
                <th>ID заказа</th>
            </tr>
            </thead>
            <tbody>
            {% if pager.nbResults == 0 %}
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">Нет данных о продажах</td>
                </tr>
            {% else %}
                {% for sale in pager.currentPageResults %}
                    <tr>
                        <td>{{ sale.sale_date|date('d.m.Y') }}</td>
                        <td><span class="badge bg-blue-lt">{{ sale.marketplace|upper }}</span></td>
                        <td><span class="badge bg-azure-lt">{{ sale.marketplace_sku }}</span></td>
                        <td>{{ sale.listing_name }}</td>
                        <td class="text-end">{{ sale.quantity }}</td>
                        <td class="text-end">{{ sale.price_per_unit|number_format(2, '.', ' ') }} ₽</td>
                        <td class="text-end"><strong>{{ sale.total_revenue|number_format(2, '.', ' ') }} ₽</strong></td>
                        <td class="text-end">
                            {% if sale.cost_price is not null and sale.cost_price > 0 %}
                                {{ sale.cost_price|number_format(2, '.', ' ') }} ₽
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td><small class="text-muted">{{ sale.external_order_id|slice(0, 20) }}...</small></td>
                    </tr>
                {% endfor %}
            {% endif %}
            </tbody>
            {% if pager.nbResults > 0 %}
                <tfoot>
                <tr>
                    <th colspan="4">На странице:</th>
                    <th class="text-end">{{ pager.currentPageResults|reduce((carry, s) => carry + s.quantity, 0) }}</th>
                    <th></th>
                    <th class="text-end">
                        <strong>{{ pager.currentPageResults|reduce((carry, s) => carry + s.total_revenue, 0)|number_format(2, '.', ' ') }} ₽</strong>
                    </th>
                    <th class="text-end">
                        <strong>{{ pager.currentPageResults|reduce((carry, s) => carry + (s.cost_price ?? 0), 0)|number_format(2, '.', ' ') }} ₽</strong>
                    </th>
                    <th></th>
                </tr>
                </tfoot>
            {% endif %}
        </table>
    </div>

    {% if pager.haveToPaginate %}
        <div class="card-footer d-flex align-items-center">
            {% include 'partials/_pagerfanta.html.twig' with {
                'pager': pager,
                'route_name': 'marketplace_sales_index',
                'route_params': selected_marketplace ? {'marketplace': selected_marketplace} : {}
            } %}
        </div>
    {% endif %}
{% endblock %}

{% block modals %}
    <div class="modal modal-blur fade" id="modal-recalculate-cost" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="{{ path('marketplace_recalculate_sales_cost_price') }}">
                    <input type="hidden" name="redirect_to" value="marketplace_sales_index">
                    <div class="modal-header">
                        <h5 class="modal-title">Пересчитать себестоимость</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label required">Маркетплейс</label>
                            <select name="marketplace" class="form-select" required>
                                <option value="">— выберите —</option>
                                {% for mp in available_marketplaces %}
                                    <option value="{{ mp.value }}"
                                        {{ selected_marketplace == mp.value ? 'selected' : '' }}>
                                        {{ mp.value|upper }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Период — начало</label>
                            <input type="date" name="date_from" class="form-control" required
                                   value="{{ 'now'|date_modify('first day of this month')|date('Y-m-d') }}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label required">Период — конец</label>
                            <input type="date" name="date_to" class="form-control" required
                                   value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="mb-0">
                            <label class="form-check">
                                <input type="checkbox" name="only_zero_cost" value="1" class="form-check-input">
                                <span class="form-check-label">Только записи с себестоимостью = 0</span>
                            </label>
                            <div class="form-hint">Если отмечено — пересчитываются только записи где costPrice не заполнена</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-link me-auto" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary" id="btn-recalculate-sales">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm me-1" width="24" height="24" viewBox="0 0 24 24"
                                 stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M5 12l5 5l10 -10"/>
                            </svg>
                            Пересчитать
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        document.getElementById('modal-recalculate-cost')
            .querySelector('form')
            .addEventListener('submit', function () {
                var btn = document.getElementById('btn-recalculate-sales');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Пересчитываем...';
            });
    </script>
{% endblock %}
