{% extends 'base.html.twig' %}

{% block title %}Настройки — Аналитика маркетплейсов{% endblock %}

{% set perPage = 50 %}
{% set pages = (total / perPage)|round(0, 'ceil') %}
{% if pages < 1 %}{% set pages = 1 %}{% endif %}

{% block content %}
    {% include 'marketplace_analytics/_tabs.html.twig' with { activeTab: 'settings' } %}

    <div class="page-body">
        <div class="container-xl">
            <div class="tab-content">
                <div class="tab-pane active show">

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible mb-3" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {# Форма добавления маппинга #}
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">Добавить маппинг</h3>
                        </div>
                        <div class="card-body"
                            data-controller="cost-mapping-add"
                            data-cost-mapping-add-add-url-value="{{ path('marketplace_analytics_api_cost_mapping_add') }}"
                        >
                            <div class="row g-2 align-items-end">

                                <div class="col-auto">
                                    <label class="form-label">Маркетплейс</label>
                                    <select name="marketplace" class="form-select"
                                        data-cost-mapping-add-target="marketplace"
                                        onchange="window.location.href='{{ path('marketplace_analytics_cost_mappings_index') }}' + '?marketplace=' + this.value">
                                        {% for mp in available_marketplaces %}
                                            <option value="{{ mp.value }}"
                                                {{ selected_marketplace == mp.value ? 'selected' }}>
                                                {{ mp.getDisplayName() }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <label class="form-label">Статья юнит-экономики</label>
                                    <select
                                        class="form-select"
                                        data-cost-mapping-add-target="costType"
                                    >
                                        <option value="">— выберите —</option>
                                        {% for type in costTypes %}
                                            <option value="{{ type.value }}">
                                                {{ type.getLabel() }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <label class="form-label">Категория затрат МП</label>
                                    <select
                                        class="form-select"
                                        data-cost-mapping-add-target="category"
                                    >
                                        <option value="">— выберите —</option>
                                        {% for cat in categories %}
                                            <option
                                                value="{{ cat.id }}"
                                                data-name="{{ cat.name|e('html_attr') }}"
                                            >{{ cat.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <button
                                        class="btn btn-primary"
                                        data-cost-mapping-add-target="submitButton"
                                        data-action="click->cost-mapping-add#add"
                                    >Добавить</button>
                                </div>

                            </div>
                        </div>
                    </div>

                    {# Таблица маппингов #}
                    <div class="card">
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Маркетплейс</th>
                                        <th>Статья юнит-экономики</th>
                                        <th>Категория затрат МП</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% if mappings is empty %}
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted">
                                                Маппинги не добавлены. Добавьте первый маппинг выше.
                                            </td>
                                        </tr>
                                    {% else %}
                                        {% for mapping in mappings %}
                                            <tr
                                                data-controller="cost-mapping-remap"
                                                data-cost-mapping-remap-remap-url-value="{{ path('marketplace_analytics_api_cost_mapping_remap', {id: mapping.id}) }}"
                                            >
                                                <td>{{ mapping.marketplace.getDisplayName() }}</td>
                                                <td>
                                                    <select
                                                        class="form-select form-select-sm w-auto"
                                                        data-cost-mapping-remap-target="select"
                                                        data-action="change->cost-mapping-remap#remap"
                                                    >
                                                        {% for type in costTypes %}
                                                            <option
                                                                value="{{ type.value }}"
                                                                {{ mapping.unitEconomyCostType.value == type.value ? 'selected' }}
                                                            >{{ type.getLabel() }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </td>
                                                <td>{{ mapping.costCategoryName }}</td>
                                                <td>
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-ghost-danger"
                                                        data-controller="cost-mapping-delete"
                                                        data-cost-mapping-delete-url-value="{{ path('marketplace_analytics_api_cost_mapping_delete', {id: mapping.id}) }}"
                                                        data-action="click->cost-mapping-delete#delete"
                                                    >Удалить</button>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        {# Пагинация #}
                        {% if pages > 1 %}
                            <div class="card-footer d-flex align-items-center">
                                <p class="m-0 text-muted">
                                    Страница {{ page }} из {{ pages }} (всего {{ total }})
                                </p>
                                <ul class="pagination m-0 ms-auto">
                                    <li class="page-item {{ page <= 1 ? 'disabled' }}">
                                        <a class="page-link" href="{{ path('marketplace_analytics_cost_mappings_index', filters|merge({page: page - 1})) }}">
                                            Назад
                                        </a>
                                    </li>
                                    <li class="page-item {{ page >= pages ? 'disabled' }}">
                                        <a class="page-link" href="{{ path('marketplace_analytics_cost_mappings_index', filters|merge({page: page + 1})) }}">
                                            Вперёд
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        {% endif %}
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
