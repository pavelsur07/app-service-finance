{% extends 'base.html.twig' %}

{% block title %}Настройки — Аналитика маркетплейсов{% endblock %}

{% set perPage = 50 %}
{% set pages = (total / perPage)|round(0, 'ceil') %}
{% if pages < 1 %}{% set pages = 1 %}{% endif %}

{% block content %}
    {% include 'marketplace_analytics/_tabs.html.twig' with { activeTab: 'settings' } %}

    <div class="page-body">
        <div class="container-xl">
            <div class="tab-content">
                <div class="tab-pane active show">

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible mb-3" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {# Форма добавления маппинга #}
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">Добавить маппинг</h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-2 align-items-end">

                                <div class="col-auto">
                                    <label class="form-label">Маркетплейс</label>
                                    <select
                                        id="select-marketplace"
                                        name="marketplace"
                                        class="form-select"
                                        onchange="window.location.href = '{{ path('marketplace_analytics_cost_mappings_index') }}' + '?marketplace=' + this.value"
                                    >
                                        {% for mp in available_marketplaces %}
                                            <option value="{{ mp.value }}"
                                                {{ selected_marketplace == mp.value ? 'selected' }}>
                                                {{ mp.getDisplayName() }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <label class="form-label">Статья юнит-экономики</label>
                                    <select id="select-cost-type" class="form-select">
                                        <option value="">— выберите —</option>
                                        {% for type in cost_types %}
                                            <option value="{{ type.value }}">
                                                {{ type.getLabel() }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <label class="form-label">Категория затрат МП</label>
                                    <select id="select-category" class="form-select">
                                        <option value="">— выберите —</option>
                                        {% for cat in categories %}
                                            <option
                                                value="{{ cat.id }}"
                                                data-name="{{ cat.name|e('html_attr') }}"
                                            >{{ cat.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <button
                                        id="btn-add-mapping"
                                        class="btn btn-primary"
                                        onclick="addCostMapping()"
                                    >Добавить</button>
                                </div>

                            </div>
                        </div>
                    </div>

                    {# Таблица маппингов #}
                    <div class="card">
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Маркетплейс</th>
                                        <th>Статья юнит-экономики</th>
                                        <th>Категория затрат МП</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% if mappings is empty %}
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted">
                                                Маппинги не добавлены. Добавьте первый маппинг выше.
                                            </td>
                                        </tr>
                                    {% else %}
                                        {% for mapping in mappings %}
                                            <tr>
                                                <td>{{ mapping.marketplace.getDisplayName() }}</td>
                                                <td>{{ mapping.unitEconomyCostType.getLabel() }}</td>
                                                <td>{{ mapping.costCategoryName }}</td>
                                                <td>
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-ghost-danger"
                                                        onclick="deleteCostMapping('{{ mapping.id }}')"
                                                    >Удалить</button>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        {# Пагинация #}
                        {% if pages > 1 %}
                            <div class="card-footer d-flex align-items-center">
                                <p class="m-0 text-muted">
                                    Страница {{ page }} из {{ pages }} (всего {{ total }})
                                </p>
                                <ul class="pagination m-0 ms-auto">
                                    <li class="page-item {{ page <= 1 ? 'disabled' }}">
                                        <a class="page-link" href="{{ path('marketplace_analytics_cost_mappings_index', filters|merge({page: page - 1})) }}">
                                            Назад
                                        </a>
                                    </li>
                                    <li class="page-item {{ page >= pages ? 'disabled' }}">
                                        <a class="page-link" href="{{ path('marketplace_analytics_cost_mappings_index', filters|merge({page: page + 1})) }}">
                                            Вперёд
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        {% endif %}
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    const ADD_URL    = '{{ path('marketplace_analytics_api_cost_mapping_add') }}';
    const DELETE_URL = '/api/marketplace-analytics/cost-mappings/';

    async function addCostMapping() {
        const marketplace  = document.getElementById('select-marketplace').value;
        const costType     = document.getElementById('select-cost-type').value;
        const categoryEl   = document.getElementById('select-category');
        const categoryId   = categoryEl.value;
        const categoryName = categoryEl.selectedOptions[0]?.dataset.name ?? '';

        if (!costType || !categoryId) {
            alert('Выберите статью и категорию затрат');
            return;
        }

        const btn = document.getElementById('btn-add-mapping');
        btn.disabled = true;

        try {
            const res = await fetch(ADD_URL, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    marketplace:         marketplace,
                    unitEconomyCostType: costType,
                    costCategoryId:      categoryId,
                    costCategoryName:    categoryName,
                }),
            });

            if (res.status === 201) {
                window.location.reload();
                return;
            }

            const data = await res.json();
            alert(data.message ?? 'Ошибка добавления');
        } catch (e) {
            alert('Ошибка сети');
        } finally {
            btn.disabled = false;
        }
    }

    async function deleteCostMapping(id) {
        if (!confirm('Удалить маппинг?')) return;

        try {
            const res = await fetch(DELETE_URL + id, {
                method: 'DELETE',
            });

            if (res.status === 204) {
                const btn = document.querySelector(
                    '[onclick="deleteCostMapping(\'' + id + '\')"]'
                );
                btn?.closest('tr')?.remove();
                return;
            }

            const data = await res.json();
            alert(data.message ?? 'Не удалось удалить маппинг');
        } catch (e) {
            alert('Ошибка сети');
        }
    }
    </script>
{% endblock %}
