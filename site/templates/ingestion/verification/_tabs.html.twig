{% set tabs = [
    { route: 'ingestion_verification_coverage', label: 'Покрытие', icon: 'ti ti-layout-grid' },
    { route: 'ingestion_verification_reconciliation', label: 'Сверка', icon: 'ti ti-scale' },
    { route: 'ingestion_verification_issues', label: 'Проблемы', icon: 'ti ti-alert-triangle' },
    { route: 'ingestion_verification_financial_summary', label: 'Финансовая сводка', icon: 'ti ti-report-money' },
] %}

<div class="page-header d-print-none mb-3">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">{{ title }}</h2>
            <div class="text-secondary mt-1">Проверка качества ingestion-данных</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body p-2">
        <ul class="nav nav-pills">
            {% for tab in tabs %}
                <li class="nav-item">
                    <a
                        class="nav-link {{ activeTab == tab.route ? 'active' : '' }}"
                        href="{{ path(tab.route) }}"
                    >
                        <i class="{{ tab.icon }} me-1" aria-hidden="true"></i>
                        {{ tab.label }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>
